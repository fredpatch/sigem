{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "rootDir": "src",
    "outDir": "dist",
    "baseUrl": ".",
    "composite": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@sigem/shared": ["../../packages/shared/src"],
      "@sigem/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "references": [{ "path": "../../packages/shared" }],
  "include": ["src"]
}
