{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2020",
    "types": ["express", "node"],
    "baseUrl": ".",
    "paths": {
      "@sigem/shared": ["../../packages/shared/src"],
      "@sigem/shared/*": ["../../packages/shared/src/*"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "references": [{ "path": "../../packages/shared" }],
  "include": ["src"]
}
